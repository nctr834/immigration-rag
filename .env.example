# Copy to .env and fill in. .env is gitignored.

OPENAI_API_KEY=sk-...

# Local Postgres with pgvector
# createdb immigration_rag && psql immigration_rag -c "CREATE EXTENSION vector;"
PGHOST=localhost
PGPORT=5432
PGDATABASE=immigration_rag
PGUSER=postgres
PGPASSWORD=postgres

# Single URL form used by the app (overrides the PG* parts above if set)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/immigration_rag
